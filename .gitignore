# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# audio assets (sirven desde GCS o symlink local en dev)
data/audio-e1/*.mp3
data/audio-e1/*.m4a
data/audio-e1/*.wav
public/audio/*.mp3

# transcripciones literales del encuentro 1 (texto crudo de lo dicho por los intendentes)
# Solo se commitea data/audio-e1/analysis/ (métricas agregadas que consume el dashboard).
data/audio-e1/transcripcion/
data/audio-e1/transcripcion-crudo-v1/

# python tooling
tools/whisperx-venv/
tools/__pycache__/
tools/*.pyc

# playwright / test artifacts
test-results/
playwright-report/
