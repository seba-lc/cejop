# Mongo
MONGODB_URI=
MONGODB_DB_SUFFIX=test

# Auth admin (login compartido del equipo)
JWT_SECRET=
ADMIN_USER=
ADMIN_PASSWORD_HASH=

# Auth Cande (magic link en /cande)
# Comma-separated, lowercased. Solo estos emails pueden pedir link al panel /cande/encuentro-1.
CANDE_ALLOWED_EMAILS=

# Resend
RESEND_API_KEY=

# URL pública base para armar los magic links en el email.
# Dev: http://localhost:3000   Prod: https://cejoptucuman.com
NEXT_PUBLIC_APP_URL=https://cejoptucuman.com

# Audio del Encuentro 1 (dashboard /cande/encuentro-1)
# En dev: usar /audio/e1.mp3 (symlink en public/audio/ apuntando a data/audio-e1/)
# En prod: URL pública de GCS marketar_bucket/cejop/audio/e1.mp3
NEXT_PUBLIC_AUDIO_E1_URL=/audio/e1.mp3
